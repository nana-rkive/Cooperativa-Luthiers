# ─── JWT ──────────────────────────────────────────────────
# Segredo utilizado para assinar e verificar os tokens JWT.
# OBRIGATÓRIO trocar em produção por um valor longo e aleatório.
JWT_SECRET=cooperativa-luthiers-secret-dev

# ─── Seed ─────────────────────────────────────────────────
# Credenciais do administrador padrão criado na inicialização.
# O SeedService é idempotente: se já existir, não recria.
ADMIN_EMAIL=admin@cooperativaluthiers.com
ADMIN_PASSWORD=Admin@1234

# ─── Servidor ─────────────────────────────────────────────
PORT=3000
